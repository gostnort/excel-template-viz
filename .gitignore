# Python
__pycache__/
*.py[cod]
.venv/


# Google OAuth 凭证（勿提交）
credentials/
*-service-account*.json
oauth_token.json
client_secret*.json
app/models/*

# NiceGUI 用户会话存储（运行时生成，勿提交）
